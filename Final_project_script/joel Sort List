import pandas as pd
import os
import csv
from abc import ABC, abstractmethod

# --- 1. MODELS (Following Page 3: Inheritance) ---
class Account(ABC):
    def __init__(self, username):
        self._username = username
    
    @abstractmethod
    def role(self):
        pass

class Admin(Account): 
    def role(self):
        return "Admin" 

class User(Account): 
    def role(self):
        return "User" 

# --- 2. SORTING LOGIC (Following Page 1: Sort List) ---
FILE_NAME = "ewaste_inventory.csv"

def sort_list():
    if not os.path.exists(FILE_NAME):
        print("Error: No inventory file found.")
        return

    try:
        df = pd.read_csv(FILE_NAME) 
        if df.empty:
            print("The list is currently empty.")
            return

        print("\n--- Sort List By ---")
        # Attributes from your Program Flow 
        options = ["Name", "Components", "Composition", "Condition", "Net Weight", "Hazard", "Recycle Rating"]
        for i, opt in enumerate(options, 1):
            print(f"{i}. {opt}")
        
        user_input = input("Select sorting attribute (1-7) or 'b' to go back: ")
        if user_input.lower() == 'b':
            return
            
        choice = int(user_input) - 1
        
        if 0 <= choice < len(options):
            attribute = options[choice]
            # Perform sorting
            sorted_df = df.sort_values(by=attribute, ascending=True)
            
            print(f"\n--- Sorted Inventory (by {attribute}) ---")
            print(sorted_df.to_string(index=False))
        else:
            print("Invalid selection.")

    except ValueError:
        print("Invalid input. Please enter a number.")
    except Exception as e:
        print(f"Error sorting list: {e}")

# --- 3. HELPER: SETUP DATA ---
def initialize_inventory():
    if not os.path.exists(FILE_NAME):
        headers = ["Name", "Components", "Composition", "Condition", "Net Weight", "Hazard", "Recycle Rating"]
        with open(FILE_NAME, "w", newline="") as f:
            writer = csv.writer(f)
            writer.writerow(headers)
            # Sample data based on your requirements
            writer.writerow(["Laptop", "Battery/PCB", "Plastic/Metal", "Used", "2.5kg", "Yes", "4"])
            writer.writerow(["Phone", "Screen/Battery", "Glass/Lithium", "Broken", "0.2kg", "Yes", "5"])
            writer.writerow(["Cable", "Copper", "Rubber", "Old", "0.5kg", "No", "3"])
        print(f"Initialized {FILE_NAME} with sample data.")

# --- 4. EXECUTION (Looping logic) ---
if __name__ == "__main__":
    initialize_inventory()
    
    while True:
        print("\n" + "="*30)
        print("  E-WASTE MANAGEMENT SYSTEM")
        print("="*30)
        print("1. Sort and View Inventory")
        print("2. Exit")
        
        choice = input("\nSelect an option (1-2): ").strip()
        
        if choice == '1':
            sort_list()
        elif choice == '2':
            print("Exiting program. Goodbye!")
            break
        else:
            print("Invalid choice. Please enter 1 or 2.")
